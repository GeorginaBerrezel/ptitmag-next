# Put ONLY variable names here, no values
# Example:
# NEXT_PUBLIC_SITE_URL=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Site — URL publique (sans slash final). Obligatoire en prod pour les liens email Supabase.
# Ex. https://www.leptitmag.org — à recopier aussi dans Supabase → Authentication → URL Configuration
NEXT_PUBLIC_SITE_URL=

# Email (Nodemailer / SMTP)
# Fournisseurs testés : OVH (ssl0.ovh.net:465), Gmail (smtp.gmail.com:587), Brevo, Mailgun…
# En prod : utiliser info@leptitmag.org (pas un Gmail perso) pour que les mails partent de l'association.
SMTP_HOST=
SMTP_PORT=
# SMTP_SECURE=true   # mettre à "true" si port 465, laisser vide pour STARTTLS (587)
SMTP_USER=
SMTP_PASS=
# Adresse qui recevra la copie admin de chaque commande (BCC)
# Par défaut : site.email (info@leptitmag.org)
ADMIN_EMAIL=

# Comptes admin (accès /admin complet) : lib/admin/access.ts
# info@leptitmag.org · georgina.berrezel@gmail.com
